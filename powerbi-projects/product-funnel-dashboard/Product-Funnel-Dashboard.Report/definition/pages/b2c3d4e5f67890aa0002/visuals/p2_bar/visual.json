{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.4.0/schema.json",
  "name": "p2_bar",
  "position": {
    "x": 20,
    "y": 400,
    "z": 0,
    "width": 820,
    "height": 300,
    "tabOrder": 7
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "fact_orders"
                    }
                  },
                  "Property": "category"
                }
              },
              "queryRef": "fact_orders.category",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Net Revenue"
                }
              },
              "queryRef": "_Measures.Net Revenue",
              "active": true
            }
          ]
        }
      }
    }
  }
}