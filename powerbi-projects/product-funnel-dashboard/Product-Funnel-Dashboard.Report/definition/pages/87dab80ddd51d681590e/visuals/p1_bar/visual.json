              "queryRef": "fact_funnel_events.region",
              "active": true
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Checkout Drop-off"
                }
              },
              "queryRef": "_Measures.Checkout Drop-off",
              "active": true
            }
          ]
        }
      }
    }
