{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/1.4.0/schema.json",
  "name": "p1_bar",
  "position": {
    "x": 770,
    "y": 540,
    "z": 0,
    "width": 490,
    "height": 150,
    "tabOrder": 11
  },
  "visual": {
    "visualType": "barChart",
    "query": {
